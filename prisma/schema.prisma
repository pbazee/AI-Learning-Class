generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String                 @id @default(uuid())
  email                   String                 @unique
  name                    String?
  avatarUrl               String?
  role                    Role                   @default(STUDENT)
  bio                     String?
  country                 String?
  preferredCurrency       String                 @default("USD")
  stripeCustomerId        String?                @unique
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  earnedDiscountCode      String?
  referralCode            String?                @unique
  referredById            String?
  aiChatSessions          AIChatSession[]
  affiliate               Affiliate?
  auditLogs               AuditLog[]
  blogComments            BlogComment[]
  blogPosts               BlogPost[]             @relation("BlogAuthor")
  certificates            Certificate[]
  coursesTaught           Course[]               @relation("InstructorCourses")
  enrollments             Enrollment[]
  progress                LessonProgress[]
  orders                  Order[]
  quizResults             QuizResult[]
  referredBy              Referral?              @relation("ReferredReferral")
  referrals               Referral[]             @relation("ReferrerReferrals")
  reviews                 Review[]
  subscriptions           UserSubscription[]
  lesson_notes            lesson_notes[]
  teamAssignmentsGiven    TeamCourseAssignment[] @relation("TeamCourseAssignmentsGiven")
  teamAssignmentsReceived TeamCourseAssignment[] @relation("TeamCourseAssignmentsReceived")
  sentTeamInvites         TeamWorkspaceInvite[]  @relation("TeamWorkspaceInviteSender")
  acceptedTeamInvites     TeamWorkspaceInvite[]  @relation("TeamWorkspaceInvitedUser")
  invitedTeamMembers      TeamWorkspaceMember[]  @relation("TeamWorkspaceInvitedBy")
  teamMemberships         TeamWorkspaceMember[]  @relation("TeamWorkspaceMemberships")
  ownedTeamWorkspaces     TeamWorkspace[]        @relation("TeamWorkspaceOwner")
  user_ai_usage           user_ai_usage[]
  user_courses            user_courses[]
  entitlements            UserEntitlement[]
  user_wishlists          user_wishlists[]
}

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  slug        String     @unique
  description String?
  icon        String?
  color       String?
  parentId    String?
  createdAt   DateTime   @default(now())
  isActive    Boolean    @default(true)
  imageUrl    String?    @map("image_url")
  imagePath   String?    @map("image_path")
  blogPosts   BlogPost[]
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  courses     Course[]
}

model Course {
  id               String                 @id @default(uuid())
  title            String
  slug             String                 @unique
  description      String
  shortDescription String?
  thumbnailUrl     String?
  previewVideoUrl  String?
  categoryId       String
  instructorId     String
  level            Level                  @default(BEGINNER)
  language         String                 @default("English")
  price            Float                  @default(0)
  originalPrice    Float?
  currency         String                 @default("USD")
  isFree           Boolean                @default(false)
  isPublished      Boolean                @default(false)
  isFeatured       Boolean                @default(false)
  isTrending       Boolean                @default(false)
  isNew            Boolean                @default(true)
  totalDuration    Int                    @default(0)
  totalLessons     Int                    @default(0)
  totalStudents    Int                    @default(0)
  rating           Float                  @default(0)
  totalRatings     Int                    @default(0)
  tags             String[]
  whatYouLearn     String[]
  requirements     String[]
  targetAudience   String[]
  certificateType  String?
  metaTitle        String?
  metaDescription  String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  isRecommended    Boolean                @default(false)
  thumbnailPath    String?
  imageUrl         String?                @map("image_url")
  imagePath        String?                @map("image_path")
  certificates     Certificate[]
  category         Category               @relation(fields: [categoryId], references: [id])
  instructor       User                   @relation("InstructorCourses", fields: [instructorId], references: [id])
  assets           CourseAsset[]
  enrollments      Enrollment[]
  modules          Module[]
  orderItems       OrderItem[]
  reviews          Review[]
  teamAssignments  TeamCourseAssignment[]
  user_courses     user_courses[]
  entitlements     UserEntitlement[]
  user_wishlists   user_wishlists[]
}

model CourseAsset {
  id          String          @id @default(uuid())
  courseId    String
  type        CourseAssetType
  title       String
  fileName    String
  storagePath String
  url         String
  mimeType    String?
  sizeBytes   Int?
  order       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  course      Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Module {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  description String?
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lessons     Lesson[]
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Lesson {
  id             String           @id @default(uuid())
  moduleId       String
  title          String
  description    String?
  type           LessonType       @default(VIDEO)
  videoUrl       String?
  duration       Int?
  content        String?
  isPreview      Boolean          @default(false)
  order          Int
  createdAt      DateTime         @default(now())
  allowDownload  Boolean          @default(false)
  assetPath      String?
  assetUrl       String?
  sellSeparately Boolean          @default(false)
  updatedAt      DateTime         @updatedAt
  previewPages   Int?             @map("preview_pages")
  previewMinutes Int?             @map("preview_minutes")
  aiPrompts      AIPrompt[]
  module         Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress       LessonProgress[]
  quizzes        Quiz[]
  lesson_notes   lesson_notes[]
}

model Quiz {
  id        String       @id @default(uuid())
  lessonId  String
  title     String
  createdAt DateTime     @default(now())
  questions Question[]
  lesson    Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  results   QuizResult[]
}

model Question {
  id          String   @id @default(uuid())
  quizId      String
  text        String
  options     String[]
  answer      Int
  explanation String?
  order       Int
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

model QuizResult {
  id          String   @id @default(uuid())
  quizId      String
  userId      String
  score       Float
  answers     Json
  completedAt DateTime @default(now())
  quiz        Quiz     @relation(fields: [quizId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model AIPrompt {
  id        String   @id @default(uuid())
  lessonId  String
  prompt    String
  context   String?
  createdAt DateTime @default(now())
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model LessonProgress {
  id             String    @id @default(uuid())
  userId         String
  lessonId       String
  isCompleted    Boolean   @default(false)
  watchedSeconds Int       @default(0)
  completedAt    DateTime?
  updatedAt      DateTime  @updatedAt
  lesson         Lesson    @relation(fields: [lessonId], references: [id])
  user           User      @relation(fields: [userId], references: [id])

  @@unique([userId, lessonId])
}

model Enrollment {
  id          String           @id @default(uuid())
  userId      String
  courseId    String
  status      EnrollmentStatus @default(ACTIVE)
  enrolledAt  DateTime         @default(now())
  completedAt DateTime?
  expiresAt   DateTime?
  course      Course           @relation(fields: [courseId], references: [id])
  user        User             @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
}

model Certificate {
  id             String   @id @default(uuid())
  userId         String
  courseId       String
  code           String   @unique
  pdfUrl         String?
  blockchainHash String?
  issuedAt       DateTime @default(now())
  course         Course   @relation(fields: [courseId], references: [id])
  user           User     @relation(fields: [userId], references: [id])
}

model Review {
  id         String   @id @default(uuid())
  userId     String
  courseId   String
  rating     Int
  title      String?
  body       String
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  isFeatured Boolean  @default(false)
  course     Course   @relation(fields: [courseId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
}

model Order {
  id              String      @id @default(uuid())
  userId          String
  status          OrderStatus @default(PENDING)
  totalAmount     Float
  currency        String      @default("USD")
  paymentMethod   String?
  paymentIntentId String?
  receiptUrl      String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]
}

model OrderItem {
  id       String @id @default(uuid())
  orderId  String
  courseId String
  price    Float
  currency String @default("USD")
  course   Course @relation(fields: [courseId], references: [id])
  order    Order  @relation(fields: [orderId], references: [id])
}

model SubscriptionPlan {
  id                  String             @id @default(uuid())
  name                String
  slug                String             @unique
  description         String?
  price               Float
  yearlyPrice         Float?
  currency            String             @default("USD")
  features            String[]
  coursesIncluded     String[]
  isPopular           Boolean            @default(false)
  isActive            Boolean            @default(true)
  stripePriceId       String?
  stripeYearlyPriceId String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  subscriptions       UserSubscription[]
}

model UserSubscription {
  id                   String             @id @default(uuid())
  userId               String
  planId               String
  status               SubscriptionStatus @default(ACTIVE)
  billingCycle         String             @default("monthly")
  stripeSubscriptionId String?
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  createdAt            DateTime           @default(now())
  plan                 SubscriptionPlan   @relation(fields: [planId], references: [id])
  user                 User               @relation(fields: [userId], references: [id])
}

model UserEntitlement {
  id                   String         @id @default(cuid())
  userId               String         @map("user_id")
  courseId             String?        @map("course_id")
  teamWorkspaceId      String?        @map("team_workspace_id")
  scope                String
  source               String
  status               String         @default("ACTIVE")
  planSlug             String?        @map("plan_slug")
  stripeSubscriptionId String?        @map("stripe_subscription_id")
  startsAt             DateTime       @default(now()) @map("starts_at") @db.Timestamptz(6)
  endsAt               DateTime?      @map("ends_at") @db.Timestamptz(6)
  metadata             Json?
  createdAt            DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  course               Course?        @relation(fields: [courseId], references: [id], onUpdate: NoAction)
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  teamWorkspace        TeamWorkspace? @relation(fields: [teamWorkspaceId], references: [id], onUpdate: NoAction, map: "user_entitlements_workspace_fk")

  @@index([planSlug, status], map: "user_entitlements_plan_status_idx")
  @@index([userId, status, endsAt], map: "user_entitlements_user_status_idx")
  @@map("user_entitlements")
}

model TeamWorkspace {
  id           String                 @id @default(cuid())
  ownerUserId  String                 @map("owner_user_id")
  name         String
  inviteCode   String                 @unique @map("invite_code")
  seatLimit    Int                    @default(10) @map("seat_limit")
  createdAt    DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  assignments  TeamCourseAssignment[]
  invites      TeamWorkspaceInvite[]
  members      TeamWorkspaceMember[]
  ownerUser    User                   @relation("TeamWorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  entitlements UserEntitlement[]

  @@index([ownerUserId], map: "team_workspaces_owner_idx")
  @@map("team_workspaces")
}

model TeamWorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String        @map("workspace_id")
  userId      String        @map("user_id")
  role        String        @default("MEMBER")
  status      String        @default("ACTIVE")
  invitedById String?       @map("invited_by_id")
  joinedAt    DateTime      @default(now()) @map("joined_at") @db.Timestamptz(6)
  revokedAt   DateTime?     @map("revoked_at") @db.Timestamptz(6)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  invitedBy   User?         @relation("TeamWorkspaceInvitedBy", fields: [invitedById], references: [id], onUpdate: NoAction)
  user        User          @relation("TeamWorkspaceMemberships", fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  workspace   TeamWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([workspaceId, userId])
  @@index([userId, status], map: "team_workspace_members_user_status_idx")
  @@map("team_workspace_members")
}

model TeamWorkspaceInvite {
  id            String        @id @default(cuid())
  workspaceId   String        @map("workspace_id")
  invitedEmail  String?       @map("invited_email")
  invitedUserId String?       @map("invited_user_id")
  invitedById   String        @map("invited_by_id")
  token         String        @unique
  status        String        @default("PENDING")
  expiresAt     DateTime      @map("expires_at") @db.Timestamptz(6)
  acceptedAt    DateTime?     @map("accepted_at") @db.Timestamptz(6)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  invitedBy     User          @relation("TeamWorkspaceInviteSender", fields: [invitedById], references: [id], onDelete: Cascade, onUpdate: NoAction)
  invitedUser   User?         @relation("TeamWorkspaceInvitedUser", fields: [invitedUserId], references: [id], onUpdate: NoAction)
  workspace     TeamWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token, status])
  @@index([workspaceId, status], map: "team_workspace_invites_workspace_status_idx")
  @@map("team_workspace_invites")
}

model TeamCourseAssignment {
  id               String        @id @default(cuid())
  workspaceId      String        @map("workspace_id")
  courseId         String        @map("course_id")
  assignedToUserId String        @map("assigned_to_user_id")
  assignedByUserId String        @map("assigned_by_user_id")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  assignedByUser   User          @relation("TeamCourseAssignmentsGiven", fields: [assignedByUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  assignedToUser   User          @relation("TeamCourseAssignmentsReceived", fields: [assignedToUserId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  course           Course        @relation(fields: [courseId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  workspace        TeamWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([workspaceId, courseId, assignedToUserId])
  @@index([workspaceId, assignedToUserId], map: "team_course_assignments_workspace_user_idx")
  @@map("team_course_assignments")
}

model HeroSlide {
  id                String   @id @default(uuid())
  title             String
  subtitle          String?
  description       String?
  imageUrl          String
  ctaText           String?
  ctaLink           String?
  order             Int      @default(0)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  imagePath         String?
  autoSlideInterval Int?
}

model Announcement {
  id        String    @id @default(uuid())
  text      String
  link      String?
  linkText  String?
  bgColor   String    @default("#7c3aed")
  isActive  Boolean   @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime  @default(now())
}

model BlogPost {
  id             String        @id @default(uuid())
  title          String
  slug           String        @unique
  excerpt        String?
  content        String
  coverImage     String?
  authorId       String
  tags           String[]
  isPublished    Boolean       @default(false)
  publishedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  categoryId     String?
  coverImagePath String?
  status         ContentStatus @default(DRAFT)
  comments       BlogComment[]
  author         User          @relation("BlogAuthor", fields: [authorId], references: [id])
  category       Category?     @relation(fields: [categoryId], references: [id])
}

model BlogComment {
  id         String   @id @default(uuid())
  postId     String
  userId     String
  content    String
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  post       BlogPost @relation(fields: [postId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
}

model NewsletterSubscriber {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  isActive     Boolean  @default(true)
  subscribedAt DateTime @default(now())
}

model Coupon {
  id           String             @id @default(uuid())
  code         String             @unique
  description  String?
  discountType CouponDiscountType
  value        Float
  expiresAt    DateTime?
  usageLimit   Int?
  usageCount   Int                @default(0)
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model Popup {
  id           String      @id @default(uuid())
  title        String
  content      String
  imageUrl     String?
  imagePath    String?
  buttonText   String?
  link         String?
  isActive     Boolean     @default(false)
  triggerRules Json?
  startsAt     DateTime?
  endsAt       DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  delaySeconds Int         @default(4)
  showOn       PopupShowOn @default(HOMEPAGE_ONLY)
}

model FAQ {
  id        String   @id @default(uuid())
  question  String
  answer    String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteSettings {
  id                String   @id @default("singleton")
  siteName          String   @default("AI Learning Class")
  supportEmail      String?
  supportPhone      String?
  adminEmail        String?
  logoUrl           String?
  faviconUrl        String?
  socialLinks       Json?
  maintenanceMode   Boolean  @default(false)
  updatedAt         DateTime @updatedAt
  supportAddress    String?
  heroSlideInterval Int      @default(6)
}

model HomepageParagraph {
  id         String   @id @default(uuid())
  sectionKey String   @unique @map("section_key")
  content    String
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("homepage_paragraphs")
}

model TrustedLogo {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @unique
  imageUrl   String   @map("image_url")
  imagePath  String?  @map("image_path")
  websiteUrl String?  @map("website_url")
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}

model ContactMessage {
  id        String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  email     String
  subject   String
  message   String
  status    ContactMessageStatus  @default(UNREAD)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @default(now()) @updatedAt
  replies   ContactMessageReply[]

  @@index([status, createdAt])
}

model ContactMessageReply {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId   String         @map("message_id") @db.Uuid
  senderName  String?        @map("sender_name")
  senderEmail String?        @map("sender_email")
  body        String
  isAdmin     Boolean        @default(true) @map("is_admin")
  createdAt   DateTime       @default(now())
  message     ContactMessage @relation(fields: [messageId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([messageId, createdAt])
}

model ReferralProgram {
  id                    String   @id @default(cuid())
  isActive              Boolean  @default(true)
  minReferrals          Int      @default(5)
  discountType          String   @default("percent")
  discountValue         Float    @default(20)
  discountExpiry        Int      @default(30)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  doubleSidedRewards    Boolean  @default(true)
  friendDiscountType    String   @default("percent")
  friendDiscountValue   Float    @default(10)
  fraudDetectionEnabled Boolean  @default(true)
}

model Referral {
  id                 String   @id @default(cuid())
  referrerId         String
  referredId         String   @unique
  status             String   @default("pending")
  rewardIssued       Boolean  @default(false)
  createdAt          DateTime @default(now())
  fraudStatus        String   @default("clear")
  fraudReason        String?
  referrerRewardCode String?
  friendRewardCode   String?
  referred           User     @relation("ReferredReferral", fields: [referredId], references: [id])
  referrer           User     @relation("ReferrerReferrals", fields: [referrerId], references: [id])
}

model AffiliateProgram {
  id                        String   @id @default(cuid())
  isActive                  Boolean  @default(true)
  commissionRate            Float    @default(20)
  minPayout                 Float    @default(10)
  cookieDays                Int      @default(30)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  payoutGraceDays           Int      @default(30)
  fraudDetectionEnabled     Boolean  @default(true)
  allowRecurringCommissions Boolean  @default(false)
}

model Affiliate {
  id               String                @id @default(cuid())
  userId           String                @unique
  status           String                @default("pending")
  affiliateCode    String                @unique
  totalClicks      Int                   @default(0)
  totalConversions Int                   @default(0)
  totalEarnings    Float                 @default(0)
  pendingPayout    Float                 @default(0)
  paidOut          Float                 @default(0)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  user             User                  @relation(fields: [userId], references: [id])
  conversions      AffiliateConversion[]
  payouts          AffiliatePayout[]
}

model AffiliateConversion {
  id          String    @id @default(cuid())
  affiliateId String
  orderId     String?
  amount      Float
  commission  Float
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  fraudStatus String    @default("clear")
  fraudReason String?
  eligibleAt  DateTime?
  creditedAt  DateTime?
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id])
}

model AffiliatePayout {
  id                 String    @id @default(cuid())
  affiliateId        String
  amount             Float
  method             String
  status             String    @default("pending")
  notes              String?
  createdAt          DateTime  @default(now())
  destinationDetails Json?
  eligibleAt         DateTime?
  processedAt        DateTime?
  affiliate          Affiliate @relation(fields: [affiliateId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  summary    String?
  metadata   Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
}

model AIChatSession {
  id        String   @id @default(uuid())
  userId    String
  courseId  String?
  lessonId  String?
  messages  Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model lesson_notes {
  id        BigInt   @id @default(autoincrement())
  user_id   String
  lesson_id String
  content   String
